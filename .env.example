# Jira — required if using tracker.kind: jira
JIRA_API_TOKEN=your-jira-api-token
JIRA_EMAIL=you@your-company.com
JIRA_SITE_URL=https://your-org.atlassian.net
JIRA_PROJECT_KEY=YOUR_PROJECT_KEY
# JIRA_ASSIGNEE=you@your-company.com  # optional: limit to your tickets

# Linear — required if using tracker.kind: linear
# LINEAR_API_KEY=lin_api_xxxxxxxxxxxxxxxxxxxx
# LINEAR_PROJECT_SLUG=your-project-slug
# LINEAR_ASSIGNEE=your-linear-user-id  # optional: limit to your issues
